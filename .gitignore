*.mp4
*.avi
*.mov
*.mkv
!public/*.mp4
!public/*.avi
!public/*.mov
!public/*.mkv

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Streamlit cache
.streamlit/

