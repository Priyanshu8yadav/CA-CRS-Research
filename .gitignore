# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
env/

# Large model weights — download separately via HuggingFace
models/*.pt
models/*.onnx
models/*.engine

# Large output / calibration data (too big for GitHub)
outputs/calibration/yolo_calibration_dataset.csv
outputs/

